{
  "name": "@muse/multi-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "eval:orchestration": "pnpm --filter @muse/model build && pnpm --filter @muse/multi-agent build && node scripts/verify-orchestration.mjs"
  },
  "dependencies": {
    "@muse/agent-core": "workspace:*",
    "@muse/memory": "workspace:*",
    "@muse/model": "workspace:*",
    "@muse/shared": "workspace:*"
  }
}
