{
  "name": "@muse/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:postgres": "MUSE_DB_POSTGRES_TEST=1 vitest run test/postgres-runtime.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@muse/shared": "workspace:*",
    "kysely": "^0.29.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0",
    "testcontainers": "^11.14.0"
  }
}
