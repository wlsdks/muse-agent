# Claude Code session state (rules / commands / agents are checked in)
.claude/scheduled_tasks.lock

# self-eval fitness log — local trend, rebuildable; not committed (avoids parallel-loop churn)
docs/self-eval-scoreboard.json

# local code-intelligence index + parallel-loop worktrees (never commit)
.codegraph/
.claude/worktrees/

# Regenerated each test-hardening loop iteration; machine-local dashboard data.
docs/test-report.json

# loop-v2 mock-corpus scratch — the loop freely generates throwaway mock data
# here and points MUSE_NOTES_DIR at it (never the real ~/.muse). The committed
# seed lives in fixtures/mock-corpus/.
.muse-dev/

# harness runner run artifact (regenerated each run)
harness/runner/last-trace.json

# stray runner-agent artifacts
__pycache__/
*.pyc

# harness runner session snapshots (run artifact)
harness/runner/sessions/

harness/runner/last-project-trace.json
