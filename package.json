{
  "name": "muse",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/wlsdks/Muse",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlsdks/Muse.git"
  },
  "bugs": {
    "url": "https://github.com/wlsdks/Muse/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort --if-present build",
    "check": "pnpm build && pnpm test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "smoke:broad": "node scripts/smoke-broad-http.mjs",
    "smoke:cli": "pnpm --filter @muse/cli build && node scripts/smoke-cli.mjs",
    "smoke:diagnostic": "node scripts/smoke-diagnostic-runtime.mjs",
    "smoke:live": "node scripts/smoke-live-llm.mjs",
    "smoke:live:all": "node scripts/smoke-live-all-providers.mjs",
    "demo": "pnpm --filter @muse/autoconfigure build && pnpm --filter @muse/mcp build && pnpm --filter @muse/messaging build && node scripts/demo.mjs",
    "dogfood:auto-extract": "pnpm --filter @muse/api build && pnpm --filter @muse/autoconfigure build && node scripts/dogfood-auto-extract.mjs",
    "dogfood:phase-d": "pnpm --filter @muse/mcp build && pnpm --filter @muse/autoconfigure build && node scripts/dogfood-phase-d.mjs",
    "test:e2e": "pnpm build && pnpm --filter @muse/web test:e2e",
    "test:e2e:live": "pnpm build && pnpm --filter @muse/web test:e2e -- live-api.spec.ts",
    "test": "pnpm -r --sort --if-present test",
    "typecheck": "pnpm -r --sort --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.18.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.5"
  }
}
